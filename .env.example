# Required -- LLM
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Required -- image primary
TOGETHER_API_KEY=

# Required -- image fallback
FAL_KEY=

# Image routing
IMAGE_PRIMARY=together
IMAGE_FALLBACK=fal

# Timeouts
LLM_TIMEOUT=45s
IMAGE_TIMEOUT=30s

# Notifications (optional)
DISCORD_WEBHOOK_URL=

# Auth (Google OAuth)
OAUTH_PROVIDER=google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8084/auth/google/callback
FRONTEND_URL=http://localhost:3004
COOKIE_DOMAIN=
COOKIE_SECURE=false
DB_PATH=./solo-adeventure.db

# Server
PORT=8084
LOG_LEVEL=info
CORS_ALLOW_ORIGIN=http://localhost:3004

# Frontend (apps/web/.env.local)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8084
